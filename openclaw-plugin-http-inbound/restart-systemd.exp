#!/usr/bin/expect -f

set timeout 60
set password "BtMZf4yGGdR0tGEj"
set host "root@154.9.252.35"

spawn ssh $host
expect "password:"
send "$password\r"

expect "# "
send "systemctl --user stop openclaw-gateway.service\r"

expect "# "
send "sleep 3\r"

expect "# "
send "systemctl --user start openclaw-gateway.service\r"

expect "# "
send "sleep 5\r"

expect "# "
send "systemctl --user status openclaw-gateway.service | head -20\r"

expect "# "
send "exit\r"

expect eof
