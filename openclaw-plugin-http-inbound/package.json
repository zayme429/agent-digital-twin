{
  "name": "@openclaw/http-inbound",
  "version": "1.0.0",
  "description": "HTTP Inbound channel for OpenClaw - allows custom apps to connect via REST API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "http-inbound",
      "label": "HTTP Inbound API",
      "description": "Connect custom applications via HTTP REST API"
    },
    "install": {
      "localPath": ".",
      "defaultChoice": "local"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "channel",
    "http",
    "api",
    "webhook",
    "custom"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "openclaw": ">=2024.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.0.0"
  }
}
