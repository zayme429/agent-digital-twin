#!/usr/bin/expect -f

set timeout 60
set password "BtMZf4yGGdR0tGEj"
set host "root@154.9.252.35"

spawn ssh $host
expect "password:"
send "$password\r"

expect "# "
send "openclaw gateway stop\r"

expect "# "
send "sleep 3\r"

expect "# "
send "openclaw gateway start\r"

expect "# "
send "sleep 5\r"

expect "# "
send "tail -50 /tmp/openclaw/openclaw-2026-03-10.log | grep -E 'runtime keys|runtime.core|runtime.channel'\r"

expect "# "
send "exit\r"

expect eof
